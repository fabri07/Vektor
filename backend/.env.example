# ══════════════════════════════════════════════════════════════════════════════
# Véktor Backend — Environment Variables
# Copy this file to .env and fill in all required values.
# Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | staging | production
DEBUG=true                         # Habilita debug logs y /docs
SECRET_KEY=change-me-in-production # Clave maestra de la app (mín. 32 chars)

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vektor
POSTGRES_USER=vektor
POSTGRES_PASSWORD=vektor           # REQUIRED — cambiar en prod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-jwt-secret  # REQUIRED — mín. 32 chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista separada por comas de orígenes permitidos
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── S3 Compatible Storage ─────────────────────────────────────────────────────
S3_ENDPOINT_URL=                   # Dejar vacío para AWS; URL para MinIO/R2
S3_ACCESS_KEY_ID=your-access-key   # REQUIRED
S3_SECRET_ACCESS_KEY=your-secret   # REQUIRED
S3_BUCKET_NAME=vektor-uploads
S3_REGION=us-east-1

# ── SMTP (notificaciones por email) ───────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@vektor.app
SMTP_PASSWORD=                     # REQUIRED en prod
SMTP_FROM_EMAIL=noreply@vektor.app
SMTP_USE_TLS=true

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_SCORE_RECALCULATION=true    # Recalcular scores ante cambios de datos
ENABLE_EMAIL_NOTIFICATIONS=false   # Habilitar envío real de emails
SCORE_RECALC_COOLDOWN_SECONDS=300  # Cooldown entre recálculos del mismo tenant
